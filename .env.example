# Slidr Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Lemon Squeezy (for $11 lifetime unlock) ───
# Create a product at https://www.lemonsqueezy.com → copy IDs here
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_VARIANT_ID=
# The checkout URL users are sent to for the $11 lifetime unlock
SLIDR_CHECKOUT_URL=https://slidr.lemonsqueezy.com/checkout

# ─── LLM Configuration (optional — set via UI instead) ───
# You can configure your LLM via the in-app Settings modal instead of env vars.
# These are only used as defaults if data/llm-config.json is absent.
# SLIDR_LLM_MODE=auto          # auto | http | cli
# SLIDR_LLM_BASE_URL=https://api.groq.com/openai/v1
# SLIDR_LLM_API_KEY=
# SLIDR_LLM_MODEL=llama-3.3-70b-versatile

# ─── Server ───
PORT=3000
